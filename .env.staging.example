# Staging environment overlay — copy to `.env.staging` and fill secrets via your secret manager.
# Use with: docker compose -f infra/docker/docker-compose.yml -f infra/docker/docker-compose.staging.yml --env-file .env.staging up -d
#
# Vendor posture: NODE_ENV=staging enforces the same fail-closed stub bans as production.
# See docs/runbooks/staging-vendor-posture.md

NODE_ENV=staging
LOG_LEVEL=info

# ── Shared internal auth (distinct from explorer read token) ──────────────────
# INTERNAL_SERVICE_TOKEN=
# EXPLORER_READ_TOKEN=

# ── Signer KMS (AWS) ─────────────────────────────────────────────────────────
KMS_PROVIDER=aws
KMS_AWS_REGION=eu-west-1
# KMS_AWS_KEY_ID=arn:aws:kms:eu-west-1:ACCOUNT:key/KEY-ID

# ── Compliance — no embedded sanctions in staging ────────────────────────────
COMPLIANCE_SANCTIONS_PROVIDER=composite
# CHAINALYSIS_API_KEY=
# COMPLYADVANTAGE_API_KEY=
# COMPLIANCE_PII_ENC_KEY=   # openssl rand -base64 32

# ── Liquidity — no stub FX / DEX fallback ────────────────────────────────────
LIQUIDITY_RATE_PROVIDER=composite
LIQUIDITY_RATE_STUB_FALLBACK=false
DEX_QUOTE_STUB_FALLBACK=false
# LIQUIDITY_QUOTE_SIGNING_SECRET=

# ── Routing — enable FIAT rail ───────────────────────────────────────────────
ROUTING_FIAT_ENABLED=true

# ── Execution — real PSP adapters ────────────────────────────────────────────
FIAT_PSP_PROVIDER=composite
# FLUTTERWAVE_SECRET_KEY=
# PAYSTACK_SECRET_KEY=
# FLUTTERWAVE_REQUIRE_BODY_HMAC=true
EXECUTION_INTERNAL_WEBHOOK_TOKEN=rotate-me-staging-internal-webhook-token

# ── Fiat listener worker ─────────────────────────────────────────────────────
FIAT_LISTENER_PORT=4020
# PAYSTACK_SECRET_KEY=          # same as execution (HMAC verification)
# FLUTTERWAVE_WEBHOOK_SECRET=   # dashboard secret hash, not API key

# ── Chain (staging testnet) ──────────────────────────────────────────────────
BASE_NETWORK=base-sepolia
BASE_RPC_URL=https://sepolia.base.org

# ── Smoke harness (optional) ─────────────────────────────────────────────────
# SMOKE_GATEWAY_URL=http://localhost:4000
# SMOKE_API_KEY=sk_test_…
# SMOKE_WALLET_ID=wal_DEMO_XRPL_TEST

# ── Observability ────────────────────────────────────────────────────────────
# OTEL_EXPORTER_OTLP_ENDPOINT=https://otel.staging.example.com
