# Developer portal (local)

PORT=3003

# Session JWT verification — MUST match the identity service JWT config.
# HS256 (default): share the same secret as services/identity JWT_SECRET.
# RS256: set AUTH_JWT_ALG=RS256 (keys are fetched from the identity JWKS endpoint).
AUTH_JWT_SECRET=change-me-in-prod-please-use-32-bytes-minimum
AUTH_JWT_ISSUER=salychain
AUTH_JWT_AUDIENCE=salychain.consumer
# AUTH_JWT_ALG=RS256

# Org the portal operates on behalf of (must exist in apikeys service).
# Required in production — there is no demo-org fallback when NODE_ENV=production.
# PORTAL_DEMO_ORG_ID remains supported as a dev-only alias.
PORTAL_ORG_ID=org_demo_acme
PORTAL_DEMO_ORG_ID=org_demo_acme
PORTAL_DEMO_OWNER_ID=usr_demo_acme

# Upstream services (server-side only — never expose to the browser)
APIKEYS_BASE_URL=http://localhost:4009
WEBHOOKS_BASE_URL=http://localhost:4010
INTENT_BASE_URL=http://localhost:4008
EXECUTION_BASE_URL=http://localhost:4003
GATEWAY_BASE_URL=http://localhost:4000
ADMIN_BASE_URL=http://localhost:4014
COMPLIANCE_BASE_URL=http://localhost:4004
IDENTITY_BASE_URL=http://localhost:4012
AGENTS_BASE_URL=http://localhost:4011
AGRI_BASE_URL=http://localhost:4025
AVIATION_BASE_URL=http://localhost:4027
EDU_BASE_URL=http://localhost:4029
FINANCE_BASE_URL=http://localhost:4023
GOV_BASE_URL=http://localhost:4024
HEALTH_BASE_URL=http://localhost:4028
SCM_BASE_URL=http://localhost:4026

# Required for /logs page (matches gateway PORTAL_INTERNAL_SECRET)
PORTAL_INTERNAL_SECRET=dev-portal-secret

# Internal service-to-service auth (x-internal-token). Shared across all
# services and server-side apps. REQUIRED in production — startup fails
# without it. When unset in development the internal API is unprotected.
# INTERNAL_SERVICE_TOKEN=rotate-me-min-16-chars

# Optional dedicated secret for the signed onboarding-gate cookie. Falls back
# to AUTH_JWT_SECRET / JWT_SECRET; required only for RS256 deployments where
# no symmetric JWT secret is configured.
# ONBOARDING_COOKIE_SECRET=change-me-32-bytes-minimum
