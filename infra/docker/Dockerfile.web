# syntax=docker/dockerfile:1.7
# =============================================================================
# Generic multi-stage image for any SalyChain Next.js app (admin/business/portal).
#
#   docker build -f infra/docker/Dockerfile.web \
#     --build-arg PACKAGE=@salychain/app-business \
#     --build-arg APP_DIR=apps/business \
#     -t ghcr.io/salychain/app-business:$TAG .
#
# Relies on Next.js `output: 'standalone'` (set in each app's next.config.mjs),
# which traces the minimal node_modules needed to run the server.
# =============================================================================
ARG NODE_VERSION=20.18-alpine

FROM node:${NODE_VERSION} AS base
ENV PNPM_HOME=/pnpm
ENV PATH=$PNPM_HOME:$PATH
RUN corepack enable && corepack prepare pnpm@9.12.0 --activate
RUN apk add --no-cache libc6-compat
WORKDIR /app

FROM base AS pruner
ARG PACKAGE
RUN pnpm add -g turbo@2.1.3
COPY . .
RUN turbo prune "${PACKAGE}" --docker

FROM base AS builder
ARG PACKAGE
ENV NEXT_TELEMETRY_DISABLED=1
COPY --from=pruner /app/out/json/ ./
RUN --mount=type=cache,id=pnpm,target=/pnpm/store pnpm install --frozen-lockfile
COPY --from=pruner /app/out/full/ ./
RUN pnpm turbo run build --filter="${PACKAGE}"

FROM node:${NODE_VERSION} AS runner
ARG APP_DIR
RUN apk add --no-cache tini
ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
ENV PORT=3000
ENV HOSTNAME=0.0.0.0
# Used by the start command (CMD exec form can't expand build args directly).
ENV SERVER_PATH=${APP_DIR}/server.js
WORKDIR /app
# Standalone bundle already contains the traced node_modules + server.
COPY --from=builder /app/${APP_DIR}/.next/standalone ./
COPY --from=builder /app/${APP_DIR}/.next/static ./${APP_DIR}/.next/static
COPY --from=builder /app/${APP_DIR}/public ./${APP_DIR}/public
USER node
ENTRYPOINT ["/sbin/tini", "--"]
CMD ["sh", "-c", "node $SERVER_PATH"]
