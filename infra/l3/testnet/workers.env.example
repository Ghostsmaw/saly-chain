# Worker env for saly-testnet hosts — copy relevant blocks per worker service.
# See docs/runbooks/d1-l3-testnet.md

L3_NETWORK=saly-testnet
L3_L3_RPC_URL=https://l3-testnet-rpc.example.com
L3_SETTLEMENT_RPC_URL=https://sepolia.base.org
# From deployments.base-sepolia.json after pnpm l3:testnet:deploy
# L3_L2_OUTPUT_ORACLE=0x...
# L3_OPTIMISM_PORTAL=0x...
# L3_SALYSD_ADDRESS=0x...

# chain-listener-l3
LISTENER_CONFIRMATIONS=2
LISTENER_BATCH_SIZE=50
LISTENER_POLL_INTERVAL_MS=4000

# l3-rollup-monitor (health :4098)
L3_POLL_INTERVAL_MS=30000

# l3-ops-monitor (health :9106, metrics :9107)
L3_OPS_HEALTH_PORT=9106
METRICS_PORT=9107

# l3-rpc-gateway
L3_RPC_UPSTREAM_URLS=https://l3-testnet-rpc.example.com
L3_RPC_RATE_LIMIT_PER_MIN=600
