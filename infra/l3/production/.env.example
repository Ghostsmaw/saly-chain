# L3 production HA stack (D3)
# Copy to .env and fill KMS/HSM-backed keys. See docs/runbooks/d3-l3-production.md

L3_NETWORK=saly-mainnet
L2_CHAIN_ID=845320003
L3_SETTLEMENT_MODE=fault_proofs

# Base mainnet settlement
L1_RPC_URL=https://mainnet.base.org
L1_RPC_KIND=standard

# OP-Stack image pins (move in lockstep)
OP_GETH_IMAGE=us-docker.pkg.dev/oplabs-tools-artifacts/images/op-geth:v1.101411.4
OP_NODE_IMAGE=us-docker.pkg.dev/oplabs-tools-artifacts/images/op-node:v1.11.2
OP_BATCHER_IMAGE=us-docker.pkg.dev/oplabs-tools-artifacts/images/op-batcher:v1.11.2
OP_PROPOSER_IMAGE=us-docker.pkg.dev/oplabs-tools-artifacts/images/op-proposer:v1.11.2
OP_CONDUCTOR_IMAGE=us-docker.pkg.dev/oplabs-tools-artifacts/images/op-conductor:v0.0.0

# Signing keys — use KMS refs in production (see runbook)
L3_SEQUENCER_PRIVATE_KEY=
L3_BATCHER_PRIVATE_KEY=
L3_PROPOSER_PRIVATE_KEY=

# Settlement contracts (from deployments.base-mainnet.json)
L3_DISPUTE_GAME_FACTORY=
L3_BATCH_INBOX=

# Ports
L3_GETH_HTTP_PORT=9545
L3_GETH_REPLICA_1_PORT=9548
L3_GETH_REPLICA_2_PORT=9549
L3_RPC_GATEWAY_PORT=9520
CONDUCTOR_1_PORT=8555
CONDUCTOR_2_PORT=8556
CONDUCTOR_3_PORT=8557
