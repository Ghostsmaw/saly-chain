# ─────────────────────────────────────────────────────────────────────────────
# SalyChain L3 OP-Stack devnet — copy to .env and fill in.
# This file is committed; .env is gitignored. NEVER put real keys in .env.example.
# ─────────────────────────────────────────────────────────────────────────────

# Settlement layer (L1 for the rollup) = Base Sepolia.
L1_RPC_URL=https://sepolia.base.org
# Optional L1 beacon (only needed for blob DA). Leave empty to use calldata DA.
L1_BEACON_RPC_URL=
L1_RPC_KIND=standard

# L3 chain id (must match packages/chain-l3 network registry: saly-devnet).
L3_NETWORK=saly-devnet
L2_CHAIN_ID=845320001

# ── Secrets — funded Base Sepolia keys (0x + 64 hex). Use dedicated devnet keys,
#    never reuse mainnet/treasury keys. preflight.sh validates format + funding. ──
L3_BATCHER_PRIVATE_KEY=
L3_PROPOSER_PRIVATE_KEY=
# Optional: defaults to the proposer key when unset.
L3_DEPLOYER_PRIVATE_KEY=
# Optional: only used if you enable p2p block signing (p2p is disabled by default).
L3_SEQUENCER_PRIVATE_KEY=

# Set after `scripts/deploy.sh` (copy from deployments.base-sepolia.json).
L3_L2_OUTPUT_ORACLE=

# ── L3 execution RPC exposed by op-geth (consumed by SalyChain services). ──
L3_L3_RPC_URL=http://127.0.0.1:9545
L3_GETH_HTTP_PORT=9545
L3_GETH_WS_PORT=9546
L3_NODE_RPC_PORT=9547

# ── DA + sequencing tuning ──
L3_DA_TYPE=calldata
SEQUENCER_L1_CONFS=4

# ── Pinned OP-Stack images (override to track a chosen Optimism release) ──
OP_GETH_IMAGE=us-docker.pkg.dev/oplabs-tools-artifacts/images/op-geth:v1.101411.4
OP_NODE_IMAGE=us-docker.pkg.dev/oplabs-tools-artifacts/images/op-node:v1.11.2
OP_BATCHER_IMAGE=us-docker.pkg.dev/oplabs-tools-artifacts/images/op-batcher:v1.11.2
OP_PROPOSER_IMAGE=us-docker.pkg.dev/oplabs-tools-artifacts/images/op-proposer:v1.11.2
OP_DEPLOYER_IMAGE=us-docker.pkg.dev/oplabs-tools-artifacts/images/op-deployer:v0.4.0-rc.1

# ── Resource limits (per container) ──
L3_GETH_MEM_LIMIT=2g
L3_GETH_CPUS=2
L3_NODE_MEM_LIMIT=1g
L3_NODE_CPUS=1
L3_BATCHER_MEM_LIMIT=512m
L3_BATCHER_CPUS=1
L3_PROPOSER_MEM_LIMIT=512m
L3_PROPOSER_CPUS=1

# ── Devnet USDC (scripts/deploy-usdc.sh) ──
# Defaults to the deployer key. Faucet drip cap is in USDC minor units (6dp).
L3_USDC_DEPLOYER_PRIVATE_KEY=
L3_USDC_FAUCET_DRIP_CAP=10000000000
L3_USDC_FAUCET_COOLDOWN=3600
L3_USDC_TREASURY_ADDRESS=
L3_USDC_TREASURY_MINT=0

# Preflight funding floor (wei) required on batcher/proposer/deployer.
MIN_FUNDING_WEI=20000000000000000
