{
  "name": "salychain",
  "version": "0.1.0",
  "private": true,
  "description": "SalyChain — AI-native financial execution network",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run build --filter='!@salychain/app-*' --filter='!@salychain/contracts-*' && turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "clean": "turbo run clean && rm -rf node_modules",
    "infra:up": "docker compose -f infra/docker/docker-compose.yml up -d",
    "infra:up:core": "docker compose -f infra/docker/docker-compose.yml up -d postgres redis nats mailhog",
    "infra:down": "docker compose -f infra/docker/docker-compose.yml down",
    "infra:logs": "docker compose -f infra/docker/docker-compose.yml logs -f",
    "infra:staging:up": "docker compose -f infra/docker/docker-compose.yml -f infra/docker/docker-compose.staging.yml --env-file .env.staging up -d",
    "smoke:health": "bash scripts/smoke/health.sh",
    "smoke:wait": "bash scripts/smoke/wait-healthy.sh",
    "smoke:partner": "bash scripts/smoke/partner-flow.sh",
    "smoke:seed-wallet": "bash scripts/smoke/seed-partner-wallet.sh",
    "smoke:prepare-staging-env": "bash scripts/smoke/prepare-staging-env.sh",
    "smoke:test": "pnpm -F @salychain/smoke-tests test",
    "stack:up": "bash scripts/start-stack.sh",
    "stack:down": "bash scripts/stop-stack.sh",
    "dr:restore-drill": "bash scripts/dr/restore-drill-local.sh",
    "custody:sign-probe": "bash scripts/custody/sign-probe.sh",
    "db:generate": "bash scripts/prisma-generate-all.sh",
    "db:migrate": "bash scripts/prisma-deploy-all.sh",
    "bootstrap:l3-envs": "bash scripts/bootstrap-l3-envs.sh",
    "l3:bootstrap": "bash infra/l3/devnet/bootstrap.sh",
    "l3:preflight": "bash infra/l3/devnet/scripts/preflight.sh",
    "l3:deploy": "bash infra/l3/devnet/scripts/deploy.sh",
    "l3:deploy:usdc": "bash infra/l3/devnet/scripts/deploy-usdc.sh",
    "l3:up": "bash infra/l3/devnet/scripts/up.sh",
    "l3:down": "bash infra/l3/devnet/scripts/down.sh",
    "l3:status": "bash infra/l3/devnet/scripts/status.sh",
    "l3:testnet:bootstrap": "bash infra/l3/testnet/bootstrap.sh",
    "l3:testnet:preflight": "bash infra/l3/testnet/scripts/preflight.sh",
    "l3:testnet:deploy": "bash infra/l3/testnet/scripts/deploy.sh",
    "l3:testnet:apply": "bash infra/l3/testnet/scripts/apply.sh",
    "l3:testnet:deploy:salysd": "bash infra/l3/testnet/scripts/deploy-salysd.sh",
    "l3:testnet:treasury:bootstrap": "bash infra/l3/testnet/scripts/treasury-bootstrap.sh",
    "l3:testnet:deploy:registry": "bash infra/l3/shared/scripts/deploy-registry.sh",
    "l3:testnet:deploy:governance": "bash infra/l3/shared/scripts/deploy-governance-base.sh",
    "l3:testnet:governance:bootstrap": "bash infra/l3/testnet/scripts/governance-bootstrap.sh",
    "l3:testnet:e-governance:apply": "bash infra/l3/testnet/scripts/e-governance-apply.sh",
    "l3:testnet:e-ops:apply": "bash infra/l3/testnet/scripts/e-ops-apply.sh",
    "l3:testnet:deploy:agents": "bash infra/l3/shared/scripts/deploy-agents.sh",
    "governance:verify": "pnpm -F @salychain/chain-l3 verify-governance",
    "verticals:verify": "pnpm -F @salychain/vertical-core typecheck && pnpm -F @salychain/service-finance -F @salychain/service-gov -F @salychain/service-agri -F @salychain/service-scm -F @salychain/service-aviation -F @salychain/service-health -F @salychain/service-edu -F @salychain/service-agents typecheck && (cd contracts/agents && forge test)",
    "verticals:seed": "node scripts/seed-verticals-demo.mjs",
    "milestone-e:verify": "pnpm -F @salychain/chain-l3 verify-milestone-e",
    "milestone-e:sync-registry-env": "bash scripts/sync-contract-registry-env.sh",
    "l3:testnet:reserve:bootstrap": "bash infra/l3/testnet/scripts/reserve-bootstrap.sh",
    "l3:testnet:e2e:bridge": "bash infra/l3/testnet/scripts/bridge-e2e.sh",
    "l3:testnet:e2e:salysd": "bash infra/l3/testnet/scripts/salysd-e2e.sh",
    "l3:testnet:status": "bash infra/l3/testnet/scripts/status.sh",
    "l3:testnet:status:remote": "bash infra/l3/testnet/scripts/status-remote.sh",
    "l3:verify": "pnpm -F @salychain/chain-l3 verify-spike",
    "l3:verify:production": "pnpm -F @salychain/chain-l3 verify-production",
    "stablecoin:verify": "pnpm -F @salychain/chain-l3 verify-stablecoin",
    "l3:production:bootstrap": "bash infra/l3/production/bootstrap.sh",
    "l3:production:preflight": "bash infra/l3/production/scripts/preflight.sh",
    "l3:production:deploy": "bash infra/l3/production/scripts/deploy.sh",
    "l3:production:deploy:mainnet": "bash infra/l3/production/scripts/deploy-mainnet.sh",
    "l3:production:apply": "bash infra/l3/production/scripts/apply.sh",
    "l3:production:up": "bash infra/l3/production/scripts/up.sh",
    "l3:production:status": "bash infra/l3/production/scripts/status.sh",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.10",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "turbo": "^2.1.3",
    "typescript": "^5.6.2"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "overrides": {
      "ioredis": "5.11.0"
    }
  }
}
