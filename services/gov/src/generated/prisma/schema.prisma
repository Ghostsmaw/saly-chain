generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OutboxStatus {
  PENDING
  PUBLISHED
  FAILED
}

model EventOutbox {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventId     String       @unique @map("event_id")
  subject     String
  payload     Json
  status      OutboxStatus @default(PENDING)
  attempts    Int          @default(0)
  lastError   String?      @map("last_error")
  createdAt   DateTime     @default(now()) @map("created_at")
  publishedAt DateTime?    @map("published_at")

  @@index([status, createdAt])
  @@map("event_outbox")
}

enum DisbursementStatus {
  PENDING
  BATCHED
  SETTLED
  FAILED
}

enum ProcurementStatus {
  OPEN
  AWARDED
  COMPLETED
  CANCELLED
}

model Program {
  id          String   @id @map("id")
  orgId       String   @map("org_id")
  name        String
  budgetMinor BigInt   @map("budget_minor")
  currency    String   @db.VarChar(8)
  eligibility Json?
  createdAt   DateTime @default(now()) @map("created_at")

  disbursements Disbursement[]

  @@index([orgId])
  @@map("programs")
}

model Beneficiary {
  id          String   @id @map("id")
  orgId       String   @map("org_id")
  programId   String   @map("program_id")
  externalRef String   @map("external_ref")
  kycStatus   String   @default("PENDING") @map("kyc_status")
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([orgId, programId, externalRef])
  @@map("beneficiaries")
}

model Disbursement {
  id            String             @id @map("id")
  orgId         String             @map("org_id")
  programId     String             @map("program_id")
  beneficiaryId String             @map("beneficiary_id")
  amountMinor   BigInt             @map("amount_minor")
  currency      String             @db.VarChar(8)
  status        DisbursementStatus @default(PENDING)
  batchIntentId String?            @map("batch_intent_id")
  createdAt     DateTime           @default(now()) @map("created_at")

  program Program @relation(fields: [programId], references: [id])

  @@index([orgId, programId, status])
  @@map("disbursements")
}

model Procurement {
  id             String            @id @map("id")
  orgId          String            @map("org_id")
  tenderRef      String            @map("tender_ref")
  title          String
  budgetMinor    BigInt            @map("budget_minor")
  currency       String            @db.VarChar(8)
  status         ProcurementStatus @default(OPEN)
  awardRef       String?           @map("award_ref")
  escrowIntentId String?           @map("escrow_intent_id")
  createdAt      DateTime          @default(now()) @map("created_at")

  @@index([orgId, status])
  @@map("procurements")
}

model PublicRecord {
  id            String   @id @map("id")
  orgId         String   @map("org_id")
  programId     String?  @map("program_id")
  recordType    String   @map("record_type")
  subjectHash   String   @map("subject_hash")
  dataHash      String   @map("data_hash")
  attestationId String?  @map("attestation_id")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([orgId, programId])
  @@map("public_records")
}
