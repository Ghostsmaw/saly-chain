generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

enum UserRole {
  SUPER_ADMIN
  BUSINESS
  DEVELOPER
  CONSUMER
}

enum UserAliasKind {
  PHONE
  EMAIL
  HANDLE
}

model User {
  id               String     @id @map("id")
  email            String     @unique
  status           UserStatus @default(ACTIVE)
  role             UserRole   @default(CONSUMER)
  displayName      String?    @map("display_name")
  passwordHash     String?    @map("password_hash")
  /// Consecutive failed password attempts; reset on successful login.
  failedLoginCount Int        @default(0) @map("failed_login_count")
  /// Account is locked (login rejected) until this instant.
  lockedUntil      DateTime?  @map("locked_until")
  metadata         Json?
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")

  delegations   DelegationGrant[]
  aliases       UserAlias[]
  refreshTokens RefreshToken[]

  @@map("users")
}

/// Opaque refresh tokens (hashed at rest). Rotated on every use; reuse of a
/// revoked token in a family revokes the entire family (theft detection).
model RefreshToken {
  id           String    @id @map("id")
  userId       String    @map("user_id")
  tokenHash    String    @unique @map("token_hash")
  familyId     String    @map("family_id")
  expiresAt    DateTime  @map("expires_at")
  revokedAt    DateTime? @map("revoked_at")
  replacedById String?   @map("replaced_by_id")
  createdAt    DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([familyId])
  @@map("refresh_tokens")
}

/// Server-side denial list for access JWTs (`jti`) — used by logout / revoke.
model AccessTokenDenial {
  jti       String   @id @map("jti")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([expiresAt])
  @@map("access_token_denials")
}

/// Lookup index for PHONE / EMAIL / HANDLE → user resolution (beneficiary routing).
model UserAlias {
  id        String        @id @map("id")
  userId    String        @map("user_id")
  kind      UserAliasKind
  value     String
  verified  Boolean       @default(false) @map("verified")
  createdAt DateTime      @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([kind, value])
  @@index([userId])
  @@map("user_aliases")
}

model DelegationGrant {
  id        String    @id @map("id")
  userId    String    @map("user_id")
  agentId   String    @map("agent_id")
  scopes    String[]
  expiresAt DateTime? @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, agentId])
  @@index([agentId])
  @@map("delegation_grants")
}
