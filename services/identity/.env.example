PORT=4012
NODE_ENV=development
LOG_LEVEL=debug
DATABASE_URL=postgresql://salychain:salychain@localhost:5433/salychain_identity?schema=public
JWT_ALG=HS256
JWT_SECRET=change-me-in-prod-please-use-32-bytes-minimum
# For production RS256, set JWT_ALG=RS256 and provide PEM-encoded keys:
# JWT_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# JWT_PUBLIC_KEY_PEM="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
# JWT_KEY_ID=salychain-identity-1
JWT_ISSUER=salychain
JWT_AUDIENCE=salychain.consumer
# Access JWT TTL (prefer ≤900s with refresh cookies). Refresh rotates on every use.
JWT_ACCESS_TTL_SEC=900
JWT_REFRESH_TTL_SEC=2592000
DEFAULT_RATE_LIMIT_PER_MIN=600
# Internal token guarding /v1/auth/token and super-admin provisioning.
# Required outside development — requests are rejected when unset.
IDENTITY_INTERNAL_ADMIN_TOKEN=dev-identity-internal-admin-token-change-me
# Super-admin bootstrap — seeded once at startup ONLY when both are set.
# There is no default account; pick a strong unique password (min 12 chars).
# SUPER_ADMIN_EMAIL=you@example.com
# SUPER_ADMIN_PASSWORD=

# Login abuse resistance (defaults shown). Lockout is per-account and
# DB-backed; the per-minute throttle is per-replica and pre-hash.
# LOGIN_MAX_FAILURES=5
# LOGIN_LOCKOUT_MINUTES=15
# LOGIN_ATTEMPTS_PER_MINUTE=10
