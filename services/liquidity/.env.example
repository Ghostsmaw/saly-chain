NODE_ENV=development
LOG_LEVEL=debug
PORT=4006

DATABASE_URL=postgresql://salychain:salychain@localhost:5433/salychain_liquidity?schema=public

# 'stub' | 'coinbase' | 'frankfurter' | 'composite' (coinbase → frankfurter [→ stub if fallback])
LIQUIDITY_RATE_PROVIDER=composite
# Dev only: allow composite to fall back to stub when live feeds fail
LIQUIDITY_RATE_STUB_FALLBACK=false

# FX cache TTL in ms (0 = disable)
LIQUIDITY_RATE_CACHE_TTL_MS=60000

# Optional API base overrides
# COINBASE_API_URL=https://api.coinbase.com
# FRANKFURTER_API_URL=https://api.frankfurter.app

# Default quote validity window in seconds. The execution service must consume
# the quote within this window or it's rejected.
LIQUIDITY_QUOTE_TTL_SECONDS=30

# Signing secret for quote tickets (HMAC-SHA256). Rotate via secret manager in prod.
LIQUIDITY_QUOTE_SIGNING_SECRET=dev-secret-rotate-me

# On-chain DEX quotes (Uniswap V3 QuoterV2 on Base)
BASE_NETWORK=base-sepolia
BASE_RPC_URL=https://sepolia.base.org
# Set true only for local dev when pool/quoter unavailable
DEX_QUOTE_STUB_FALLBACK=false
# Live on-chain DEX E2E: DEX_E2E_LIVE=true pnpm --filter @salychain/chain-base test -- dex.live.spec.ts
