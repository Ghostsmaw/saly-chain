NODE_ENV=development
LOG_LEVEL=debug
PORT=4010

DATABASE_URL=postgresql://salychain:salychain@localhost:5433/salychain_webhook?schema=public
REDIS_URL=redis://localhost:6379
NATS_URL=nats://localhost:4222

# Default delivery timeout in ms. Subscribers SHOULD respond < 3s; we cap at 10s.
DELIVERY_TIMEOUT_MS=10000

# Maximum number of attempts before a delivery moves to the dead-letter queue.
MAX_DELIVERY_ATTEMPTS=8

# A connection refused / DNS failure / 5xx is retried with this base delay (ms),
# scaled exponentially with jitter (cap 1h).
DELIVERY_BASE_BACKOFF_MS=2000

# When a request signing-secret is auto-generated, this is its length in bytes.
SIGNING_SECRET_BYTES=32
# AES-256-GCM key sealing signing secrets at rest (base64, 32 bytes).
# Required in production. Generate with:  openssl rand -base64 32
# WEBHOOK_SECRET_ENC_KEY=

# Internal service-to-service auth (x-internal-token). Shared across all
# services and server-side apps. REQUIRED in production — startup fails
# without it. When unset in development the internal API is unprotected.
# INTERNAL_SERVICE_TOKEN=rotate-me-min-16-chars
