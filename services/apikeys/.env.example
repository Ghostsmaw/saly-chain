NODE_ENV=development
LOG_LEVEL=debug
PORT=4009

DATABASE_URL=postgresql://salychain:salychain@localhost:5433/salychain_apikeys?schema=public

# Server-side pepper added to every secret hash. NEVER rotated without a secret-rolling job
# (existing hashes use the old pepper, so we keep a list of pepper versions in prod).
APIKEY_HASH_PEPPER=dev-pepper-rotate-me

# Default rate-limit budget assigned to newly-issued API keys (per minute).
DEFAULT_RATE_LIMIT_PER_MIN=600

# Internal service-to-service auth (x-internal-token). Shared across all
# services and server-side apps. REQUIRED in production — startup fails
# without it. When unset in development the internal API is unprotected.
# INTERNAL_SERVICE_TOKEN=rotate-me-min-16-chars

# Shared platform Redis (same instance the gateway uses). When set, key
# revocation immediately evicts the gateway's verify cache instead of
# waiting out APIKEY_CACHE_TTL_SEC.
# REDIS_URL=redis://localhost:6379
