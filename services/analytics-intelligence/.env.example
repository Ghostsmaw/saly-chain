# SalyChain Intelligence Service (B8)
NODE_ENV=development
LOG_LEVEL=info
PORT=4019

# Derived-intelligence store (entities, embeddings, NL query logs)
DATABASE_URL=postgresql://salychain:salychain@localhost:5433/salychain_intelligence?schema=public

# Background jobs (entity resolution, embedding materialization)
REDIS_URL=redis://localhost:6379

# Analytics source (read-only ClickHouse)
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_USER=salychain
CLICKHOUSE_PASSWORD=salychain
CLICKHOUSE_DATABASE=salychain_analytics
QUERY_MAX_ROWS=500000
QUERY_TIMEOUT_SECONDS=60

# Entity resolution
RESOLUTION_LOOKBACK_DAYS=90
RESOLUTION_MIN_SHARED=2
RESOLUTION_MAX_ADDRESSES=100000

# Embeddings (deterministic local embedder — no external model)
EMBEDDING_DIM=64

# Natural-language analytics (rule planner by default; LLM disabled)
INTELLIGENCE_LLM_ENABLED=false

# OpenTelemetry (optional)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
