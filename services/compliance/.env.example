NODE_ENV=development
LOG_LEVEL=debug
PORT=4004

DATABASE_URL=postgresql://salychain:salychain@localhost:5433/salychain_compliance?schema=public

# Sanctions provider: embedded | chainalysis | comply | refinitiv | composite
COMPLIANCE_SANCTIONS_PROVIDER=composite

# Vendor credentials (enable per environment)
# CHAINALYSIS_API_KEY=
# CHAINALYSIS_API_URL=https://api.chainalysis.com
# COMPLYADVANTAGE_API_KEY=
# COMPLYADVANTAGE_API_URL=https://api.complyadvantage.com
# REFINITIV_API_KEY=
# REFINITIV_API_SECRET=
# REFINITIV_GROUP_ID=
# REFINITIV_API_URL=https://api-worldcheck.refinitiv.com

# KYC provider: 'manual' (dev — admin marks tiers by hand), 'sumsub', 'onfido', 'persona'
COMPLIANCE_KYC_PROVIDER=manual

# AES-256-GCM key (base64, 32 bytes) for KYC/KYB step payloads at rest — required in production
# COMPLIANCE_PII_ENC_KEY=

# INTERNAL_SERVICE_TOKEN=rotate-me-min-16-chars
