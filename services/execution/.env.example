NODE_ENV=development
LOG_LEVEL=debug
PORT=4003

DATABASE_URL=postgresql://salychain:salychain@localhost:5433/salychain_execution?schema=public
NATS_URL=nats://localhost:4222

LEDGER_BASE_URL=http://localhost:4001
WALLET_BASE_URL=http://localhost:4002
# Set to false to skip ledger reserve/settle for chain payouts (legacy dev)
LEDGER_CHAIN_RESERVATION_ENABLED=true
COMPLIANCE_BASE_URL=http://localhost:4004
RISK_BASE_URL=http://localhost:4005
LIQUIDITY_BASE_URL=http://localhost:4006
ROUTING_BASE_URL=http://localhost:4007
# Deployed SalyEscrow on Base — required when routing selects ESCROW rail
# ESCROW_CONTRACT_ADDRESS_BASE=0x...
# ESCROW_RESOLVER_WALLET_ID=<uuid of resolver custodial wallet>
# EXECUTION_ADMIN_TOKEN=rotate-me-min-16-chars
# BASE_NETWORK=base-sepolia
# BASE_RPC_URL=https://sepolia.base.org

# Fiat PSP — stub | flutterwave | paystack | composite
FIAT_PSP_PROVIDER=stub
# FLUTTERWAVE_SECRET_KEY=
# PAYSTACK_SECRET_KEY=
# FIAT_CONFIRMATION_POLL_MS=10000
# Default business fiat source: liability.business.{actor_id}.{currency}
# EXECUTION_FIAT_SOURCE_ACCOUNT_PREFIX=liability.business

# Real fiat pay-in (C2): PSP settled-cash assets land at asset.bank.{provider}.{CCY}
# EXECUTION_PAYIN_BANK_ACCOUNT_PREFIX=asset.bank

# Ledger ↔ rail reconciliation poller (off by default; opt in for ops environments)
# EXECUTION_RECONCILIATION_ENABLED=false
# EXECUTION_RECONCILIATION_INTERVAL_MS=300000
# Mark pay-ins unfunded past this many minutes as EXPIRED during reconciliation
# EXECUTION_PAYIN_EXPIRY_MINUTES=1440

# Bearer token for fiat-listener → POST /v1/internal/fiat/confirmations and /v1/internal/fiat/payins
# EXECUTION_INTERNAL_WEBHOOK_TOKEN=

# SalySD treasury wallets (Milestone D5)
# SALYSD_MINTER_WALLET_ID=
# SALYSD_BURNER_WALLET_ID=
# L3_NETWORK=saly-testnet

# Redeem fiat payout defaults (stub PSP / dev)
# SALYSD_REDEEM_FIAT_CURRENCY=USD
# SALYSD_REDEEM_FIAT_COUNTRY=US
# SALYSD_REDEEM_FIAT_ACCOUNT=000123456789
# SALYSD_REDEEM_FIAT_BANK_CODE=021000021
# SALYSD_REDEEM_FIAT_HOLDER=Demo Recipient
# SALYSD_REDEEM_FIAT_SOURCE_ACCOUNT_ID=
