{
  "name": "@salychain/service-analytics-api",
  "version": "0.1.0",
  "private": true,
  "description": "Saly Realtime APIs — read-only REST over the ClickHouse analytics store (transfers, balances, tx lineage, stablecoin supply, sandboxed queries)",
  "type": "module",
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@clickhouse/client": "^1.7.0",
    "@nestjs/common": "^10.4.4",
    "@nestjs/core": "^10.4.4",
    "@nestjs/platform-express": "^10.4.4",
    "@salychain/config": "workspace:*",
    "@salychain/errors": "workspace:*",
    "@salychain/logger": "workspace:*",
    "@salychain/observability": "workspace:*",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.5",
    "@nestjs/testing": "^10.4.4",
    "@types/node": "^20.14.10",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  }
}
