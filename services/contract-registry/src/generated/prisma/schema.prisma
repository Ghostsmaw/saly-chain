generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ContractStatus {
  ACTIVE
  PAUSED
  DEPRECATED
}

enum ControlKind {
  NONE
  PAUSABLE
}

enum ExecutionMode {
  DB_ONLY
  ON_CHAIN
}

enum ProposalStatus {
  PENDING
  SUBMITTED
  EXECUTED
  FAILED
  CANCELLED
}

model DeployedContract {
  id              String         @id
  name            String
  purpose         String
  network         String
  address         String
  version         String
  status          ContractStatus @default(ACTIVE)
  tvlUsd          Int            @default(0) @map("tvl_usd")
  audited         Boolean        @default(false)
  deployedAt      DateTime       @map("deployed_at")
  chainId         Int?           @map("chain_id")
  controlKind     ControlKind    @default(NONE) @map("control_kind")
  executionMode   ExecutionMode  @default(DB_ONLY) @map("execution_mode")
  timelockAddress String?        @map("timelock_address")
  governorAddress String?        @map("governor_address")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  upgrades           ContractUpgrade[]
  proposals          StatusProposal[]
  attestationIssuers AttestationIssuer[]

  @@map("deployed_contracts")
}

model ContractUpgrade {
  id           String   @id
  contractId   String?  @map("contract_id")
  contractName String   @map("contract_name")
  fromVersion  String   @map("from_version")
  toVersion    String   @map("to_version")
  upgradedAt   DateTime @map("upgraded_at")
  approvedBy   String   @map("approved_by")
  createdAt    DateTime @default(now()) @map("created_at")

  contract DeployedContract? @relation(fields: [contractId], references: [id])

  @@map("contract_upgrades")
}

model StatusProposal {
  id             String         @id
  contractId     String         @map("contract_id")
  action         String
  status         ProposalStatus @default(PENDING)
  actorRef       String?        @map("actor_ref")
  txHash         String?        @map("tx_hash")
  calldata       String?        @map("calldata")
  broadcastJobId String?        @map("broadcast_job_id")
  error          String?        @map("error")
  createdAt      DateTime       @default(now()) @map("created_at")
  executedAt     DateTime?      @map("executed_at")

  contract DeployedContract @relation(fields: [contractId], references: [id])

  @@map("status_proposals")
}

model GovernanceDeployment {
  id              String   @id
  network         String
  chainId         Int      @map("chain_id")
  tokenAddress    String   @map("token_address")
  timelockAddress String   @map("timelock_address")
  governorAddress String   @map("governor_address")
  deployedAt      DateTime @map("deployed_at")
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("governance_deployments")
}

model AttestationIssuer {
  id                 String   @id
  registryContractId String   @map("registry_contract_id")
  issuerAddress      String   @map("issuer_address")
  vertical           String
  accredited         Boolean  @default(false)
  onChainTxHash      String?  @map("on_chain_tx_hash")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  registryContract DeployedContract @relation(fields: [registryContractId], references: [id])

  @@unique([registryContractId, issuerAddress])
  @@map("attestation_issuers")
}
