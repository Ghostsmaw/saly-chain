NODE_ENV=development
LOG_LEVEL=debug
PORT=4000

DATABASE_URL=postgresql://salychain:salychain@localhost:5433/salychain_gateway?schema=public
REDIS_URL=redis://localhost:6379

APIKEYS_BASE_URL=http://localhost:4009
INTENT_BASE_URL=http://localhost:4008
EXECUTION_BASE_URL=http://localhost:4003
WEBHOOKS_BASE_URL=http://localhost:4010
AGENTS_BASE_URL=http://localhost:4011
IDENTITY_BASE_URL=http://localhost:4012
WALLET_BASE_URL=http://localhost:4002
DATA_BASE_URL=http://localhost:4016
DATASTREAMS_BASE_URL=http://localhost:4017
DATASHARES_BASE_URL=http://localhost:4018
INTELLIGENCE_BASE_URL=http://localhost:4019
MERCHANT_BASE_URL=http://localhost:4021

# How long apikey verification results are cached per (prefix, secret-hash).
# Keep tight in prod (we want revocations to take effect quickly).
APIKEY_CACHE_TTL_SEC=15
# Number of trusted reverse proxies (ALB/Cloudflare) in front of the gateway.
# Client IPs for ip_allow_list come from this — do not overcount.
TRUST_PROXY_HOPS=1

# Idempotency replay window: a same-key request within this window returns
# the cached response. Standard industry practice is 24h.
IDEMPOTENCY_WINDOW_SECONDS=86400

# Shared secret for the developer portal server-side log fetch (X-Portal-Secret).
PORTAL_INTERNAL_SECRET=dev-portal-secret

# Internal service-to-service auth — attached automatically by the SDK HttpClient
# to every internal call (x-internal-token). Must match the token configured on
# ledger/wallet/execution/apikeys/webhooks.
# INTERNAL_SERVICE_TOKEN=rotate-me-min-16-chars

# Max FAILED credential attempts per client IP per minute. Failures beyond
# this are rejected before any scrypt/JWT verification work.
AUTH_FAILURE_LIMIT_PER_MIN=30
