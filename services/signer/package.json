{
  "name": "@salychain/service-signer",
  "version": "0.1.0",
  "private": true,
  "description": "SalyChain isolated transaction signing service (KMS / MPC backed)",
  "type": "module",
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "kms:rewrap": "tsx scripts/kms-rewrap.ts",
    "clean": "rm -rf dist .turbo node_modules/.prisma"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.4",
    "@nestjs/core": "^10.4.4",
    "@nestjs/platform-express": "^10.4.4",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/terminus": "^10.2.3",
    "@prisma/client": "^5.20.0",
    "@salychain/chain-xrpl": "workspace:*",
    "@salychain/config": "workspace:*",
    "@salychain/observability": "workspace:*",
    "@salychain/errors": "workspace:*",
    "@salychain/logger": "workspace:*",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "reflect-metadata": "^0.2.2",
    "ripple-keypairs": "^2.0.0",
    "rxjs": "^7.8.1",
    "@aws-sdk/client-kms": "^3.679.0",
    "ulid": "^2.3.0",
    "viem": "^2.21.19",
    "xrpl": "^4.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.5",
    "@nestjs/testing": "^10.4.4",
    "@types/node": "^20.14.10",
    "prisma": "^5.20.0",
    "typescript": "^5.6.2",
    "tsx": "^4.19.1",
    "vitest": "^2.1.1"
  }
}
