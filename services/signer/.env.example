NODE_ENV=development
LOG_LEVEL=debug
PORT=4099

# Use its own database. In production this is a dedicated cluster with no
# shared credentials with application services.
DATABASE_URL=postgresql://salychain:salychain@localhost:5433/salychain_signer?schema=public

# KMS provider: 'local' (dev only) or 'aws' (prod).
KMS_PROVIDER=local

# ── Local (dev/test) ──
# Base64-encoded 32-byte AES-256 master key. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
KMS_LOCAL_MASTER_KEY=ZGV2LW9ubHktbWFzdGVyLWtleS1yZXBsYWNlLW1lLWluLXByb2Q=

# ── AWS KMS (staging/prod) ──
# KMS_PROVIDER=aws
# KMS_AWS_REGION=us-east-1
# KMS_AWS_KEY_ID=alias/salychain-signer          # or full CMK ARN
# KMS_AWS_ENDPOINT=                              # optional — LocalStack / VPC endpoint
# Credentials via ECS task role / IRSA (no access keys in env)
