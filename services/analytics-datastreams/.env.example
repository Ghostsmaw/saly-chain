NODE_ENV=development
LOG_LEVEL=debug
PORT=4017

DATABASE_URL=postgresql://salychain:salychain@localhost:5433/salychain_datastreams?schema=public
REDIS_URL=redis://localhost:6379
NATS_URL=nats://localhost:4222

# Webhook sink delivery tuning (mirrors the webhooks service).
DELIVERY_TIMEOUT_MS=10000
MAX_DELIVERY_ATTEMPTS=8
DELIVERY_BASE_BACKOFF_MS=2000
SIGNING_SECRET_BYTES=32
# Auto-disable a stream after this many consecutive delivery failures.
AUTO_DISABLE_THRESHOLD=50

# Kafka / Redpanda sink. Disabled by default so the service boots without a
# broker; set to "true" once a broker is reachable to allow KAFKA streams.
DATASTREAMS_KAFKA_ENABLED=false
DATASTREAMS_KAFKA_BROKERS=localhost:9092
DATASTREAMS_KAFKA_CLIENT_ID=salychain-datastreams
# Every tenant Kafka topic must start with this prefix (defense-in-depth).
DATASTREAMS_KAFKA_TOPIC_PREFIX=salychain.datastreams.
