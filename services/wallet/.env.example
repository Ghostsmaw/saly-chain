NODE_ENV=development
LOG_LEVEL=debug
PORT=4002

DATABASE_URL=postgresql://salychain:salychain@localhost:5433/salychain_wallet?schema=public
REDIS_URL=redis://localhost:6379
NATS_URL=nats://localhost:4222

SIGNER_BASE_URL=http://localhost:4099
LEDGER_BASE_URL=http://localhost:4001
AGENTS_BASE_URL=http://localhost:4011

# Base network configuration. Use base-sepolia for development.
BASE_NETWORK=base-sepolia
BASE_RPC_URL=https://sepolia.base.org
# Default caps for newly provisioned BASE wallets (USDC minor units)
WALLET_BASE_DEFAULT_PER_TX_CAP_MINOR=10000000000
WALLET_BASE_DEFAULT_DAILY_CAP_MINOR=100000000000
# Deployed SalyEscrow — required for ESCROW_FUND transfers (see docs/runbooks/s3-escrow-fund-deal.md)
# ESCROW_CONTRACT_ADDRESS=0x...
# WALLET_INTERNAL_ADMIN_TOKEN=rotate-me-min-16-chars

XRPL_NETWORK=xrpl-testnet
XRPL_WS_URL=wss://s.altnet.rippletest.net:51233
# IOU currency → issuer map (JSON). Example Bitstamp USD issuer.
XRPL_IOU_ISSUERS={"USD":"rhub8VRN55s94qWKDv6jmDy1pUykJzF3wq"}
XRPL_DEFAULT_TRUST_LIMIT=1000000
WALLET_XRPL_DEFAULT_PER_TX_CAP_MINOR=1000000000
WALLET_XRPL_DEFAULT_DAILY_CAP_MINOR=10000000000

# Saly L3 devnet (S6 money rail) — see docs/runbooks/s6-l3-money-rail.md
L3_NETWORK=saly-devnet
L3_L3_RPC_URL=http://127.0.0.1:9545
# L3_USDC_ADDRESS=0x...
WALLET_L3_DEFAULT_PER_TX_CAP_MINOR=10000000000
WALLET_L3_DEFAULT_DAILY_CAP_MINOR=100000000000

# Ethereum / Polygon — schema-only in Tier 2 (provision blocked until adapters ship)
# See docs/runbooks/s8-multi-chain-wallets.md
