NODE_ENV=development
LOG_LEVEL=debug
PORT=4008

DATABASE_URL=postgresql://salychain:salychain@localhost:5433/salychain_intent?schema=public
NATS_URL=nats://localhost:4222

# Downstream — the execution service that owns the lifecycle once an intent is accepted.
EXECUTION_BASE_URL=http://localhost:4003

# Internal service-to-service auth — attached automatically by the SDK HttpClient
# to every internal call (x-internal-token). Must match the token configured on
# ledger/wallet/execution/apikeys/webhooks.
# INTERNAL_SERVICE_TOKEN=rotate-me-min-16-chars
