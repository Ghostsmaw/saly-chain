generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OutboxStatus {
  PENDING
  PUBLISHED
  FAILED
}

model EventOutbox {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventId     String       @unique @map("event_id")
  subject     String
  payload     Json
  status      OutboxStatus @default(PENDING)
  attempts    Int          @default(0)
  lastError   String?      @map("last_error")
  createdAt   DateTime     @default(now()) @map("created_at")
  publishedAt DateTime?    @map("published_at")

  @@index([status, createdAt])
  @@map("event_outbox")
}

enum ShipmentStatus {
  CREATED
  IN_TRANSIT
  DELIVERED
  SETTLED
}

enum SettlementStatus {
  PENDING
  ESCROW_FUNDED
  RELEASED
  CANCELLED
}

model Product {
  id        String   @id @map("id")
  orgId     String   @map("org_id")
  sku       String
  name      String
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([orgId, sku])
  @@map("products")
}

model Shipment {
  id          String         @id @map("id")
  orgId       String         @map("org_id")
  productId   String?        @map("product_id")
  origin      String
  destination String
  status      ShipmentStatus @default(CREATED)
  createdAt   DateTime       @default(now()) @map("created_at")

  custody CustodyEvent[]
  docs    TradeDoc[]

  @@index([orgId, status])
  @@map("shipments")
}

model CustodyEvent {
  id            String   @id @map("id")
  orgId         String   @map("org_id")
  shipmentId    String   @map("shipment_id")
  actorRef      String   @map("actor_ref")
  geo           Json?
  attestationId String?  @map("attestation_id")
  createdAt     DateTime @default(now()) @map("created_at")

  shipment Shipment @relation(fields: [shipmentId], references: [id])

  @@index([shipmentId])
  @@map("custody_events")
}

model TradeDoc {
  id         String   @id @map("id")
  orgId      String   @map("org_id")
  shipmentId String   @map("shipment_id")
  docType    String   @map("doc_type")
  dataHash   String   @map("data_hash")
  createdAt  DateTime @default(now()) @map("created_at")

  shipment Shipment @relation(fields: [shipmentId], references: [id])

  @@index([shipmentId])
  @@map("trade_docs")
}

model TradeFinance {
  id             String   @id @map("id")
  orgId          String   @map("org_id")
  shipmentId     String   @map("shipment_id")
  financierRef   String   @map("financier_ref")
  amountMinor    BigInt   @map("amount_minor")
  currency       String   @db.VarChar(8)
  payoutIntentId String?  @map("payout_intent_id")
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([orgId])
  @@map("trade_finance")
}

model ScmSettlement {
  id             String           @id @map("id")
  orgId          String           @map("org_id")
  shipmentId     String           @map("shipment_id")
  amountMinor    BigInt           @map("amount_minor")
  currency       String           @db.VarChar(8)
  status         SettlementStatus @default(PENDING)
  escrowIntentId String?          @map("escrow_intent_id")
  createdAt      DateTime         @default(now()) @map("created_at")

  @@index([orgId, status])
  @@map("scm_settlements")
}
