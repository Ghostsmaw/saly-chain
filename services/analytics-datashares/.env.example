NODE_ENV=development
LOG_LEVEL=debug
PORT=4018

DATABASE_URL=postgresql://salychain:salychain@localhost:5433/salychain_datashares?schema=public
REDIS_URL=redis://localhost:6379

# Curated dataset source (read-only ClickHouse).
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_USER=salychain
CLICKHOUSE_PASSWORD=salychain
CLICKHOUSE_DATABASE=salychain_analytics
SHARE_RUN_MAX_ROWS=1000000
QUERY_TIMEOUT_SECONDS=60

# HMAC key used to deterministically pseudonymize (hash) PII columns. MUST be a
# stable secret in production so hashes are consistent across runs.
DATASHARES_REDACTION_SECRET=dev-redaction-secret-change-me

# Object-store (S3 / MinIO) export destination.
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=salychain
S3_SECRET_KEY=salychain-dev
S3_BUCKET=salychain-lake
S3_REGION=us-east-1
DATASHARES_EXPORT_PREFIX=exports

# Warehouse-native destinations require vendor drivers + credentials and are
# disabled by default. While disabled, shares targeting them are rejected at
# create-time.
DATASHARES_SNOWFLAKE_ENABLED=false
DATASHARES_BIGQUERY_ENABLED=false
DATASHARES_DATABRICKS_ENABLED=false
