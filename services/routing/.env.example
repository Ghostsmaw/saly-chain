NODE_ENV=development
LOG_LEVEL=debug
PORT=4007

DATABASE_URL=postgresql://salychain:salychain@localhost:5433/salychain_routing?schema=public

# Weights for the rail score (higher = better). Must sum to 100.
ROUTING_WEIGHT_COST=40
ROUTING_WEIGHT_SPEED=30
ROUTING_WEIGHT_RELIABILITY=20
ROUTING_WEIGHT_PRIVACY=10

# Rail enable flags (operational switches independent of policy).
ROUTING_INTERNAL_ENABLED=true
ROUTING_BASE_ENABLED=true
ROUTING_XRPL_ENABLED=true
ROUTING_L3_ENABLED=true
ROUTING_FIAT_ENABLED=false
# Staging: ROUTING_FIAT_ENABLED=true (see .env.staging.example)

# Base network for on-chain DEX pair eligibility (must match liquidity/wallet)
BASE_NETWORK=base-sepolia

# Fiat PSP — stub | flutterwave | paystack | composite
FIAT_PSP_PROVIDER=stub
# FLUTTERWAVE_SECRET_KEY=
# PAYSTACK_SECRET_KEY=
