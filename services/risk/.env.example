NODE_ENV=development
LOG_LEVEL=debug
PORT=4005

DATABASE_URL=postgresql://salychain:salychain@localhost:5433/salychain_risk?schema=public
REDIS_URL=redis://localhost:6379

# Default scoring thresholds (basis points 0..100). Per-actor overrides land in S3.
RISK_REVIEW_THRESHOLD=60
RISK_BLOCK_THRESHOLD=85

# Intelligence (B8) counterparty enrichment. Fail-open when enabled.
RISK_INTELLIGENCE_ENABLED=false
INTELLIGENCE_BASE_URL=http://localhost:4019
