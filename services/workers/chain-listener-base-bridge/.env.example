# Wallet Postgres — chain listener checkpoints (shared with wallet service)
DATABASE_URL=postgresql://salychain:salychain@localhost:5433/salychain_wallet?schema=public

# NATS JetStream
NATS_URL=nats://localhost:4222

# Base settlement layer
BASE_NETWORK=base-sepolia
BASE_RPC_URL=https://sepolia.base.org

# L3 rail (manifest auto-applies bridge addresses when present)
L3_NETWORK=saly-testnet
# L3_OPTIMISM_PORTAL=0x...
# L3_L1_STANDARD_BRIDGE=0x...
# L3_DEPLOYMENTS_FILE=../../../infra/l3/testnet/deployments.base-sepolia.json

LISTENER_BATCH_SIZE=50
LISTENER_POLL_INTERVAL_MS=4000
LISTENER_CONFIRMATIONS=2
METRICS_PORT=9102

NODE_ENV=development
LOG_LEVEL=info
