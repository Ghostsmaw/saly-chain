NODE_ENV=development
LOG_LEVEL=debug

PORT=4020
DATABASE_URL=postgresql://salychain:salychain@localhost:5433/salychain_fiat_listener?schema=public

EXECUTION_BASE_URL=http://localhost:4003
# Must match EXECUTION_INTERNAL_WEBHOOK_TOKEN on the execution service.
# Used for both payout confirmations and inbound pay-in credits.
EXECUTION_INTERNAL_WEBHOOK_TOKEN=dev-internal-webhook-token-change-me

# Paystack — HMAC SHA512 verification uses the secret key. The single webhook URL
# receives both transfer.* (payout) and charge.* (pay-in) events.
PAYSTACK_SECRET_KEY=

# Flutterwave — dashboard secret hash (Settings → Webhooks), not the API secret key.
FLUTTERWAVE_WEBHOOK_SECRET=

# Optional IP allowlist (comma-separated). Leave empty when behind a trusted ingress.
# WEBHOOK_ALLOWED_IPS=
