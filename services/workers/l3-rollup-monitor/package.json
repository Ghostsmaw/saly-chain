{
  "name": "@salychain/worker-l3-rollup-monitor",
  "version": "0.1.0",
  "private": true,
  "description": "Observes Saly L3 OP-Stack output proposals posted to Base (settlement layer)",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@salychain/chain-l3": "workspace:*",
    "@salychain/config": "workspace:*",
    "@salychain/events": "workspace:*",
    "@salychain/logger": "workspace:*",
    "@salychain/observability": "workspace:*",
    "ulid": "^2.3.0",
    "viem": "^2.21.19",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}
