NODE_ENV=development
LOG_LEVEL=debug

# The listener uses its own small Postgres for checkpoint state. Pointing at
# the wallet DB is fine in dev because the worker uses a dedicated table.
DATABASE_URL=postgresql://salychain:salychain@localhost:5433/salychain_wallet?schema=public
NATS_URL=nats://localhost:4222

BASE_NETWORK=base-sepolia
BASE_RPC_URL=https://sepolia.base.org

# How many blocks to look at per poll. Conservative default.
LISTENER_BATCH_SIZE=50
LISTENER_POLL_INTERVAL_MS=4000
# How many confirmations before a settlement is emitted.
LISTENER_CONFIRMATIONS=2
# SalyEscrow contract — indexes DealFunded events when set
# ESCROW_CONTRACT_ADDRESS=0x...
