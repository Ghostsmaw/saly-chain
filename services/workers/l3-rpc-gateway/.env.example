# Comma-separated internal op-geth URLs (sequencer + read replicas)
L3_RPC_UPSTREAM_URLS=http://127.0.0.1:9545,http://127.0.0.1:9548
L3_NETWORK=saly-mainnet

# Public JSON-RPC (read-only policy enforced)
L3_RPC_GATEWAY_PORT=9520
L3_RPC_RATE_LIMIT_PER_MIN=600

METRICS_PORT=9111
NODE_ENV=development
LOG_LEVEL=info
