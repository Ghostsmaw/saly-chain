NODE_ENV=development
LOG_LEVEL=debug

# Shares the wallet DB's checkpoint table (partitioned by chain_key), like Base.
DATABASE_URL=postgresql://salychain:salychain@localhost:5433/salychain_wallet?schema=public
NATS_URL=nats://localhost:4222

L3_NETWORK=saly-devnet
L3_L3_RPC_URL=http://127.0.0.1:9545
# L3_USDC_ADDRESS=0x...

LISTENER_BATCH_SIZE=50
LISTENER_POLL_INTERVAL_MS=4000
LISTENER_CONFIRMATIONS=2
