{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "module": "Node16",
    "moduleResolution": "Node16",
    "target": "ES2022",
    "verbatimModuleSyntax": false,
    "useDefineForClassFields": false
  },
  "include": ["src/**/*"]
}
