{
  "name": "@salychain/resilience-tests",
  "version": "0.1.0",
  "private": true,
  "description": "E2E, chaos, and load-script validation for SalyChain resilience (Milestone C4)",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:e2e": "vitest run src/e2e",
    "test:chaos": "vitest run src/chaos",
    "test:load-scripts": "vitest run src/load",
    "clean": "rm -rf .turbo"
  },
  "dependencies": {
    "@salychain/finality": "workspace:*",
    "@salychain/sdk-internal": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  }
}
