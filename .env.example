NODE_ENV=development
LOG_LEVEL=debug

DATABASE_URL=postgresql://salychain:salychain@localhost:5433/salychain?schema=public
REDIS_URL=redis://localhost:6379
NATS_URL=nats://localhost:4222

OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
SENTRY_DSN=

LEDGER_SERVICE_PORT=4001
WALLET_SERVICE_PORT=4002
EXECUTION_SERVICE_PORT=4003
COMPLIANCE_SERVICE_PORT=4004
RISK_SERVICE_PORT=4005
LIQUIDITY_SERVICE_PORT=4006
ROUTING_SERVICE_PORT=4007
INTENT_SERVICE_PORT=4008
SIGNER_SERVICE_PORT=4099
API_GATEWAY_PORT=4000
APIKEYS_SERVICE_PORT=4009
WEBHOOKS_SERVICE_PORT=4010
AGENTS_SERVICE_PORT=4011
IDENTITY_SERVICE_PORT=4012
CONTRACT_REGISTRY_SERVICE_PORT=4013
ADMIN_SERVICE_PORT=4014
ADMIN_DATABASE_URL=postgresql://salychain:salychain@localhost:5433/salychain_admin?schema=public

ADMIN_APP_PORT=3001
PORTAL_APP_PORT=3003
BUSINESS_APP_PORT=3002

JWT_SECRET=change-me-in-prod-please
JWT_ISSUER=salychain
JWT_AUDIENCE=salychain.internal

BASE_NETWORK=base-sepolia
BASE_RPC_URL=https://sepolia.base.org
BASE_USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e
# On-chain DEX quotes (liquidity service) — set false for real QuoterV2 pricing
DEX_QUOTE_STUB_FALLBACK=false
# Live on-chain DEX E2E (chain-base dex.live.spec.ts) — off by default
# DEX_E2E_LIVE=true
# Default signer caps for new BASE wallets (USDC minor units, 6 decimals)
WALLET_BASE_DEFAULT_PER_TX_CAP_MINOR=10000000000
WALLET_BASE_DEFAULT_DAILY_CAP_MINOR=100000000000

# ── Fiat payouts (Tier 2) ────────────────────────────────────────────────────
# Enable FIAT rail in routing + wire PSP adapters in execution
# ROUTING_FIAT_ENABLED=true
# FIAT_PSP_PROVIDER=composite
# PAYSTACK_SECRET_KEY=sk_test_...
# FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-...
# EXECUTION_INTERNAL_WEBHOOK_TOKEN=rotate-me-min-16-chars
# FIAT_LISTENER_PORT=4020
# BUSINESS_FIAT_NGN_LEDGER_ACCOUNT=<uuid of NGN treasury liability account>
XRPL_NETWORK=xrpl-testnet
XRPL_WS_URL=wss://s.altnet.rippletest.net:51233
XRPL_IOU_ISSUERS={"USD":"rhub8VRN55s94qWKDv6jmDy1pUykJzF3wq"}
XRPL_DEFAULT_TRUST_LIMIT=1000000

KMS_PROVIDER=local
# Production: KMS_PROVIDER=aws + KMS_AWS_REGION + KMS_AWS_KEY_ID (see services/signer/.env.example)
# Generate local dev key: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
KMS_LOCAL_MASTER_KEY=ZGV2LW9ubHktbWFzdGVyLWtleS1yZXBsYWNlLW1lLWluLXByb2Q=

EXECUTION_BASE_URL=http://localhost:4003
# Ledger FX pool account prefix for SWAP intents (accounts created as asset.fx.{CURRENCY})
EXECUTION_FX_POOL_ACCOUNT_PREFIX=asset.fx
COMPLIANCE_BASE_URL=http://localhost:4004
# Sanctions vendors (services/compliance — see services/compliance/.env.example)
# COMPLIANCE_SANCTIONS_PROVIDER=composite
# CHAINALYSIS_API_KEY=
# COMPLYADVANTAGE_API_KEY=
RISK_BASE_URL=http://localhost:4005
LIQUIDITY_BASE_URL=http://localhost:4006
ROUTING_BASE_URL=http://localhost:4007
INTENT_BASE_URL=http://localhost:4008
APIKEYS_BASE_URL=http://localhost:4009
WEBHOOKS_BASE_URL=http://localhost:4010
AGENTS_BASE_URL=http://localhost:4011
IDENTITY_BASE_URL=http://localhost:4012
CONTRACT_REGISTRY_BASE_URL=http://localhost:4013
ADMIN_BASE_URL=http://localhost:4014
WALLET_BASE_URL=http://localhost:4002
GATEWAY_BASE_URL=http://localhost:4000

# Super-admin invites — shared between identity + admin services (optional in dev).
IDENTITY_INTERNAL_ADMIN_TOKEN=dev-identity-internal-admin-token-change-me
# Admin console URL embedded in invite emails
ADMIN_CONSOLE_URL=http://localhost:3001
# RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=onboarding@resend.dev

# Liquidity service signing secret — rotate in prod via secret manager.
LIQUIDITY_QUOTE_SIGNING_SECRET=dev-secret-rotate-me
# Treasury FX rate feeds: composite = Coinbase → Frankfurter (real market data)
LIQUIDITY_RATE_PROVIDER=composite
LIQUIDITY_RATE_STUB_FALLBACK=false
LIQUIDITY_RATE_CACHE_TTL_MS=60000

# B2B surface (S3) — rotate in prod via secret manager.
# Used by services/apikeys to peppercorn-hash API key secrets at rest.
APIKEY_HASH_PEPPER=dev-pepper-rotate-me
# Used by services/webhooks to compute X-Saly-Signature on outbound deliveries
# (per-subscription secret is also generated on subscribe; this is the global fallback).
WEBHOOKS_FALLBACK_SECRET=dev-secret-rotate-me
# Public-facing portal app URL — embedded into welcome emails and docs links.
PORTAL_BASE_URL=http://localhost:3003

# Staging overlay — see .env.staging.example and infra/staging/README.md
# ROUTING_FIAT_ENABLED=true
# FIAT_PSP_PROVIDER=composite
# EXECUTION_INTERNAL_WEBHOOK_TOKEN=

# L3 OP-Stack devnet (S5 spike) — see docs/runbooks/s5-l3-devnet-rollup.md
L3_NETWORK=saly-devnet
L3_SETTLEMENT_RPC_URL=https://sepolia.base.org
# L3_L2_OUTPUT_ORACLE=0x...  # or use manifest below
# L3_DEPLOYMENTS_FILE=infra/l3/devnet/deployments.base-sepolia.json
# L3_MONITOR_HEALTH_URL=http://127.0.0.1:4098/health
# L3_MONITOR_STATE_DIR=.l3-monitor
# L3_USDC_ADDRESS=0x...  # L3 devnet USDC (S6 money rail)
# ROUTING_L3_ENABLED=true

# Milestone E — governance + vertical registry ops
# GOVERNANCE_EXECUTOR_WALLET_ID=<uuid from pnpm l3:testnet:governance:bootstrap>
# L3_ATTESTATION_REGISTRY_ADDRESS=0x...
# L3_SALYSD_ADDRESS=0x...
# CONTRACT_REGISTRY env also needs WALLET_BASE_URL + L3_L3_RPC_URL (see services/contract-registry/.env.example)
# pnpm l3:testnet:e-ops:apply          # full E0–E7 ops (migrations + optional on-chain)
# pnpm milestone-e:verify              # local exit gate
# MILESTONE_E_ON_CHAIN=1 pnpm milestone-e:verify   # after on-chain deploy
# Vertical services (gateway proxy defaults)
# FINANCE_BASE_URL=http://localhost:4023
# GOV_BASE_URL=http://localhost:4024
# AGRI_BASE_URL=http://localhost:4025
# SCM_BASE_URL=http://localhost:4026
# AVIATION_BASE_URL=http://localhost:4027
# HEALTH_BASE_URL=http://localhost:4028
# EDU_BASE_URL=http://localhost:4029
